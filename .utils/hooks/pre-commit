#!/usr/bin/env sh
# Git pre-commit hook: 自动为 .sh 文件添加可执行权限

set -e

# 获取暂存区中新增或修改的 .sh 文件
SH_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.sh$' || true)

if [ -n "$SH_FILES" ]; then
    for FILE in $SH_FILES; do
        if [ -f "$FILE" ]; then
            # 使用 git update-index 添加可执行权限
            echo "🔧 为 $FILE 添加可执行权限"
            chmod +x "$FILE"
            git update-index --chmod=+x "$FILE"
        fi
    done
fi

exit 0
