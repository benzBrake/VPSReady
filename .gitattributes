# Shell scripts - ensure LF line endings
# 注意：可执行权限由 .git/hooks/pre-commit hook 自动管理
*.sh eol=lf

# Ensure consistent line endings for text files
*.text eol=lf
*.md eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mo binary
*.pdf binary
